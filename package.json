    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "ai",
    "agents",
    "llm",
    "claude",
    "context",
    "recall",
    "episodic",
    "semantic"
  ],
  "author": "Keith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitfunso/hippo-memory"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.11.0"
  }
}
