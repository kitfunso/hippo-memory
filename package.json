{
  "name": "hippo-memory",
  "version": "0.4.0",
  "description": "Biologically-inspired memory system for AI agents. Decay by default, strength through use.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "hippo": "./bin/hippo.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "ai",
    "agents",
    "llm",
    "claude",
    "context",
    "recall",
    "episodic",
    "semantic",
    "embeddings",
    "hybrid-search"
  ],
  "author": "Keith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitfunso/hippo-memory.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.11.0"
  },
  "peerDependencies": {
    "@xenova/transformers": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  }
}
