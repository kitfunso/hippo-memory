{
  "name": "hippo-memory",
  "version": "0.1.0",
  "description": "Biologically-inspired memory system for AI agents. Decay by default, strength through use.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "hippo": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
